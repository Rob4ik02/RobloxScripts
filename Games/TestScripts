NormalSection2:AddButton({
    Name = "Destroy Gui",
    Callback = function()
        Notifier.new({
            Title = "02: Notification",
            Content = "The UI and CoreGui elements will be destroyed in 5 seconds.",
            Duration = 4,
            Icon = "rbxassetid://102643647961511"
        });
        
        task.wait(5);
        
        -- Попытка закрыть через Window
        pcall(function()
            if Window.Destroy then Window:Destroy() end
        end)

        -- Глубокая очистка CoreGui от следов compkiller
        local CoreGui = game:GetService("CoreGui")
        for _, object in ipairs(CoreGui:GetChildren()) do
            if string.find(string.lower(object.Name), "compkiller") then
                pcall(function() object:Destroy() end)
            end
        end
    end,
})

