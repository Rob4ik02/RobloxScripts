local AutoPunchRockActive = false
local StandPosition = Vector3.new(-2591.58, 7.26, -244.1)
local MachineRemote = game:GetService("ReplicatedStorage"):WaitForChild("rEvents"):WaitForChild("machineInteractRemote")

local AutoPunchRock = NormalSection2:AddToggle({
    Name = "Auto Punch Rock",
    Flag = "Toggle_PunchFrozenRock", 
    Default = false,
    Callback = function(v)
        playInterfaceSound("ButtonClick")
        AutoPunchRockActive = v
        
        local character = player.Character
        local hrp = character and character:FindFirstChild("HumanoidRootPart")
        local rockModel = workspace.machinesFolder:FindFirstChild("Frozen Rock")
        local targetRock = rockModel and rockModel:FindFirstChild("Rock")

        if AutoPunchRockActive and hrp and targetRock then
            -- Плавный полет к камню
            local TweenService = game:GetService("TweenService")
            local TargetCFrame = CFrame.lookAt(StandPosition, targetRock.Position)
            TweenService:Create(hrp, info, {CFrame = TargetCFrame}):Play()
            
            task.wait(1.2)

            -- ОСНОВНОЙ ЦИКЛ
            task.spawn(function()
                local step = 0
                while AutoPunchRockActive do
                    -- 1. Микро-движение для обновления хитбокса (персонаж будет чуть-чуть дрожать)
                    step = step + 1
                    local shift = math.sin(step) * 0.05 -- Движение на 0.05 пикселя
                    hrp.CFrame = TargetCFrame * CFrame.new(0, 0, shift)

                    -- 2. Отправка сигнала на сервер (RemoteFunction)
                    pcall(function()
                        MachineRemote:InvokeServer(rockModel)
                    end)
                    
                    -- 3. Удар предметом
                    local punch = character:FindFirstChild("Punch") or player.Backpack:FindFirstChild("Punch")
                    if punch then
                        if punch.Parent == player.Backpack then
                            character.Humanoid:EquipTool(punch)
                        end
                        punch:Activate()
                    end
                    
                    -- 4. Если урон перестал идти, пробуем перенадеть тулз раз в 5 секунд
                    if step % 100 == 0 then
                        character.Humanoid:UnequipTools()
                        task.wait(0.1)
                    end

                    task.wait(0.05)
                end
            end)
        else
            -- При выключении просто даем свободу движений
            if hrp then hrp.Anchored = false end
        end
    end,
})

