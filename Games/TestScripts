-- Инициализация библиотеки UI
local library = loadstring(game:HttpGet("https://raw.githubusercontent.com/i77lhm/Libraries/refs/heads/main/Millenium/Library.lua"))()

-- Создание главного окна
local window = library:window({name = "Global Script's", suffix = " | Come Back.", gameInfo = "Universal Usement Gui"})
window:seperator({name = "Main"})

-- Создание вкладок
local statusTab, updatesTab, creditsTab = window:tab({name = "Home", tabs = {"Status", "Updates & News", "Credits"}})

-- Глобальные флаги для управления логикой скрипта
local flags = {
    esp_enabled = false,
    esp_color = Color3.fromRGB(255, 50, 50),
    walkspeed = 16,
    jumppower = 50,
    aimbot_enabled = false
}

-- Сервисы Roblox
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local LocalPlayer = Players.LocalPlayer

-- ==========================================
-- Вкладка: VISUALS (Визуальные функции)
-- ==========================================
local visColumn = visualsTab:column({})
local espSection = visColumn:section({name = "ESP Settings", default = true})

espSection:toggle({name = "Enable Highlight ESP", seperator = true, callback = function(state)
    flags.esp_enabled = state
    -- Очистка ESP при выключении
    if not state then
        for _, player in ipairs(Players:GetPlayers()) do
            if player ~= LocalPlayer and player.Character then
                local highlight = player.Character:FindFirstChild("AgentESP")
                if highlight then highlight:Destroy() end
            end
        end
    end
end})

-- Настройка цвета ESP (использование colorpicker из библиотеки)
local colorToggle = espSection:toggle({name = "ESP Color", seperator = true})
colorToggle:colorpicker({callback = function(color)
    flags.esp_color = color
end})

-- ==========================================
-- Вкладка: LOCAL PLAYER (Управление персонажем)
-- ==========================================
local playerColumn = playerTab:column({})
local movementSection = playerColumn:section({name = "Movement Modification", default = true})

movementSection:slider({name = "WalkSpeed", min = 16, max = 300, interval = 1, callback = function(val)
    flags.walkspeed = val
end})

movementSection:slider({name = "JumpPower", min = 50, max = 300, interval = 1, callback = function(val)
    flags.jumppower = val
end})

-- ==========================================
-- Вкладка: COMBAT (Каркас для боевых функций)
-- ==========================================
local combatColumn = combatTab:column({})
local aimSection = combatColumn:section({name = "Aimbot Settings", default = true})

aimSection:toggle({name = "Enable Aimbot (Template)", seperator = true, callback = function(state)
    flags.aimbot_enabled = state
    if state then
        print("[System]: Боевой протокол активирован.")
    else
        print("[System]: Боевой протокол деактивирован.")
    end
end})

aimSection:dropdown({name = "Target Part", items = {"Head", "HumanoidRootPart", "Torso"}, default = "Head", multi = false, seperator = true, callback = function(selected)
    print("[System]: Цель изменена на " .. tostring(selected))
end})

-- ==========================================
-- ОСНОВНОЙ ЦИКЛ ОБРАБОТКИ (Main Loop)
-- ==========================================
RunService.RenderStepped:Connect(function()
    -- 1. Обработка параметров локального игрока
    local character = LocalPlayer.Character
    if character and character:FindFirstChild("Humanoid") then
        character.Humanoid.WalkSpeed = flags.walkspeed
        -- В Roblox Studio у новых Humanoid используется UseJumpPower = true для старого JumpPower
        character.Humanoid.UseJumpPower = true 
        character.Humanoid.JumpPower = flags.jumppower
    end

    -- 2. Обработка ESP
    if flags.esp_enabled then
        for _, player in ipairs(Players:GetPlayers()) do
            if player ~= LocalPlayer then
                local pChar = player.Character
                if pChar and pChar:FindFirstChild("HumanoidRootPart") and pChar:FindFirstChild("Humanoid") and pChar.Humanoid.Health > 0 then
                    local highlight = pChar:FindFirstChild("AgentESP")
                    if not highlight then
                        highlight = Instance.new("Highlight")
                        highlight.Name = "AgentESP"
                        highlight.FillTransparency = 0.5
                        highlight.OutlineTransparency = 0
                        highlight.Parent = pChar
                    end
                    -- Обновляем цвет в реальном времени
                    highlight.FillColor = flags.esp_color
                    highlight.OutlineColor = Color3.new(1, 1, 1)
                elseif pChar and pChar:FindFirstChild("Humanoid") and pChar.Humanoid.Health <= 0 then
                    -- Удаляем ESP с мертвых
                    local highlight = pChar:FindFirstChild("AgentESP")
                    if highlight then highlight:Destroy() end
                end
            end
        end
    end
end)

-- Финализация и загрузка конфигурации UI
library:init_config(window)
