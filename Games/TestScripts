    ["WarnSound"] = "rbxassetid://136001454409424",
    ["NotificationSound"] = "rbxassetid://134195160579609",
    ["CompleteSound"] = "rbxassetid://3320590485",
    ["LoadedSound"] = "rbxassetid://117683281438895",
