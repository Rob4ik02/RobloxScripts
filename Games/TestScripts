local function getStatusString()
    local character = localPlayer.Character
    local humanoid = character and character:FindFirstChildOfClass("Humanoid")
    
    if humanoid then
        return "Nickname: " .. localPlayer.Name .. "\n" ..
               "UserId: " .. localPlayer.UserId .. "\n" ..
               "Health: " .. math.floor(humanoid.Health) .. "/" .. math.floor(humanoid.MaxHealth) .. "\n" ..
               "WalkSpeed: " .. math.floor(humanoid.WalkSpeed) .. "\n" ..
               "JumpPower: " .. math.floor(humanoid.JumpPower)
    else
        return "Character not found"
    end
end

-- Создаем параграф
local PlayerParagraph = StatusHome:Paragraph({
