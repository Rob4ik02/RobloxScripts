NormalSection1:AddButton({
    Name = "Destroy Gui",
    Callback = function()
        Notifier.new({
            Title = "02: Notification",
            Content = "Starting deep clean of CoreGui...",
            Duration = 3,
            Icon = "rbxassetid://102643647961511"
        });

        -- Ждем 5 секунд как в оригинале
        task.wait(5)

        -- Пытаемся закрыть через саму библиотеку (на всякий случай)
        pcall(function()
            if Window and Window.Destroy then
                Window:Destroy()
            end
        end)

        -- Глубокая очистка CoreGui
        local CoreGui = game:GetService("CoreGui")
        local found = false

        for _, object in ipairs(CoreGui:GetChildren()) do
            -- Ищем совпадение в названии (регистр не важен)
            if string.find(string.lower(object.Name), "compkiller") then
                local success, err = pcall(function()
                    object:Destroy()
                end)
                
                if success then
                    found = true
                    print("[Cleaner]: Удален объект: " .. object.Name)
                else
                    warn("[Cleaner Error]: Не удалось удалить " .. object.Name .. " | " .. tostring(err))
                end
            end
        end

        -- Финальное уведомление
        if found then
            print("[Cleaner]: Все связанные GUI удалены.")
        else
            -- Если по имени не нашли, попробуем удалить твой конкретный GUI, 
            -- который мы видим на скриншоте (u?name=compkiller...)
            for _, object in ipairs(CoreGui:GetChildren()) do
                 if object:IsA("ScreenGui") and string.len(object.Name) > 20 then -- Обычно у них длинные имена
                    object:Destroy()
                 end
            end
        end
    end,
})
